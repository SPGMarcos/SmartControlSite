DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-development
JWT_SECRET_KEY=change-me-in-development

# Optional deploy/bootstrap logins. On Render, set these as secret env vars.
# The deploy updates the password every time these variables are present.
SMARTCONTROL_ADMIN_EMAIL=admin@example.com
SMARTCONTROL_ADMIN_PASSWORD=change-this-admin-password
SMARTCONTROL_ADMIN_FIRST_NAME=Admin
SMARTCONTROL_ADMIN_LAST_NAME=SmartControl

# Optional client login for demos/tests.
# SMARTCONTROL_CLIENT_EMAIL=cliente@example.com
# SMARTCONTROL_CLIENT_PASSWORD=change-this-client-password
# SMARTCONTROL_CLIENT_FIRST_NAME=Cliente
# SMARTCONTROL_CLIENT_LAST_NAME=
# SMARTCONTROL_CLIENT_COMPANY=SmartControl Cliente
# SMARTCONTROL_CLIENT_PHONE=

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,smartcontrol-sites-api.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://spgmarcos.github.io,https://smartcontrol-sites-api.onrender.com,https://smartcontrol-sites-frontend.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://spgmarcos.github.io,https://smartcontrol-sites-api.onrender.com,https://smartcontrol-sites-frontend.onrender.com

FRONTEND_URL=http://127.0.0.1:5173
FRONTEND_ORIGIN=http://127.0.0.1:5173
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

POSTGRES_DB=smartcontrol_sites
POSTGRES_USER=smartcontrol
POSTGRES_PASSWORD=smartcontrol_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# In production, prefer Render's DATABASE_URL/Internal Database URL.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://127.0.0.1:5173/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://127.0.0.1:5173/billing?checkout=cancel
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:5173/billing
